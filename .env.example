# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (true/false)
DEBUG=true

# Database
DATABASE_URL=sqlite:///./lead_intelligence.db
# For PostgreSQL: postgresql+psycopg2://user:password@localhost/lead_db

# Logging
LOG_LEVEL=INFO
# LOG_FILE=logs/application.log

# External API Configuration
API_TIMEOUT=30
API_MAX_RETRIES=3

# AI Enrichment (Optional)
# ENRICHMENT_API_KEY=your_api_key_here
# ENRICHMENT_MODEL_PROVIDER=openai  # or anthropic, local, etc.
# ENRICHMENT_TEMPERATURE=0.7
# ENRICHMENT_MAX_TOKENS=1000

# Adapter Configuration (Optional)
# OPENCORPORATES_API_TOKEN=your_opencorporates_token_here
# SCRAPER_TIMEOUT=30
# SCRAPER_USER_AGENT=Lead-Intelligence-Bot/1.0
# SCRAPER_HEADLESS=true

# Export Configuration (Optional)
# EXPORT_FORMAT=csv  # csv, json, excel
# EXPORT_PATH=./exports/
